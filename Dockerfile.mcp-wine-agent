# Bun MCP Wine Agent server (JIT - no build step)
FROM oven/bun:1-alpine

WORKDIR /app

# Copy everything (client excluded via .dockerignore)
COPY . .

# Install workspace deps for MCP agent only (include dev deps for widget build)
RUN bun install --frozen-lockfile --filter "mcp-wine-agent"

# Build widget assets at image build time
WORKDIR /app/usecases/wine-shop/mcp
RUN bun run build:widget
WORKDIR /app

USER bun
ENV NODE_ENV=production
ENV PORT=30123
ENV MCP_PATH=/mcp
ENV SKIP_WIDGET_BUILD=1

EXPOSE 30123

CMD ["bun", "run", "usecases/wine-shop/mcp/src/main.ts"]
