# Local localhost defaults live in .env.local.
# For local setup, create a .env file with the custom values below.

VIDOS_AUTHORIZER_URL=https://your-authorizer-host/authorizer

# Optional when your authorizer expects bearer authentication.
VIDOS_API_KEY=your-vidos-api-key

PUBLIC_BASE_URL=https://your-public-mcp-host
PORT=44182
MCP_PATH=/mcp

# Optional local helper flags.
# DEBUG_MCP_SERVER=0
# SKIP_WIDGET_BUILD=1
